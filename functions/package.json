{
  "name": "functions",
  "description": "Cloud Functions for Firebase - TrámiteYA",
  "scripts": {
    "build": "tsc",
    "clean": "rimraf lib",
    "seed": "ts-node --transpile-only scripts/seedServices.ts",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "npm run build && firebase deploy --only functions"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^12.5.0",
    "firebase-functions": "^5.0.0",
    "nodemailer": "^8.0.4"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.11",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "private": true
}
