{
  "functions": { "source": "functions" },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "web",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/notify", "function": { "region": "us-central1", "functionId": "notify" } },
      { "source": "/payments_init",    "function": "payments_init" },
      { "source": "/payments_confirm", "function": "payments_confirm" },
      { "source": "/admin_upload",     "function": "admin_upload" },
      { "source": "/services",         "function": "services" },
      { "source": "/orders",           "function": "orders" }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "emulators": {
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 },
    "storage":   { "port": 9199 },
    "hosting":   { "port": 5000 },
    "ui":        { "enabled": true },
    "import": "./emulator-data",
    "exportOnExit": "./emulator-data"
  }
}
